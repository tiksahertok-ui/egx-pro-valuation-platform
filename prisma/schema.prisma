// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Post {
  id        String   @id @default(cuid())
  title     String
  content   String?
  published Boolean  @default(false)
  authorId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Stock {
  id               String   @id @default(cuid())
  ticker           String   @unique
  name             String
  nameAr           String
  sector           String
  industry         String
  isin             String   @default("")
  yahooSymbol      String   @default("")
  marketCap        Float    @default(0)
  price            Float    @default(0)
  sharesOutstanding Float   @default(0)
  beta             Float    @default(1.0)
  egx30Beta        Float    @default(1.0)
  dividendYield    Float    @default(0)
  peRatio          Float    @default(0)
  pbRatio          Float    @default(0)
  eps              Float    @default(0)
  bookValuePerShare Float   @default(0)
  fiftyTwoWeekHigh Float    @default(0)
  fiftyTwoWeekLow  Float    @default(0)
  avgVolume        Float    @default(0)
  description      String   @default("")
  descriptionAr    String   @default("")
  lastPriceAt      DateTime?
  lastFinancialsAt DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  priceHistory      PriceHistory[]
  technicalIndicators TechnicalIndicator[]
}

model PriceHistory {
  id        String   @id @default(cuid())
  stockId   String
  date      DateTime
  open      Float
  high      Float
  low       Float
  close     Float
  volume    Float
  adjClose  Float    @default(0)
  createdAt DateTime @default(now())

  stock     Stock    @relation(fields: [stockId], references: [id], onDelete: Cascade)

  @@unique([stockId, date])
}

model TechnicalIndicator {
  id            String   @id @default(cuid())
  stockId       String
  date          DateTime
  rsi14         Float    @default(0)
  macdLine      Float    @default(0)
  macdSignal    Float    @default(0)
  macdHist      Float    @default(0)
  bbUpper       Float    @default(0)
  bbMiddle      Float    @default(0)
  bbLower       Float    @default(0)
  sma20         Float    @default(0)
  sma50         Float    @default(0)
  sma200        Float    @default(0)
  ema12         Float    @default(0)
  ema26         Float    @default(0)
  atr14         Float    @default(0)
  adx14         Float    @default(0)
  stochasticK   Float    @default(0)
  stochasticD   Float    @default(0)
  williamsR     Float    @default(0)
  cci14         Float    @default(0)
  obv           Float    @default(0)
  createdAt     DateTime @default(now())

  stock         Stock    @relation(fields: [stockId], references: [id], onDelete: Cascade)

  @@unique([stockId, date])
}

model SectorStats {
  id              String   @id @default(cuid())
  sector          String   @unique
  sectorAr        String   @default("")
  avgPE           Float    @default(0)
  avgPB           Float    @default(0)
  avgROE          Float    @default(0)
  avgROA          Float    @default(0)
  avgDebtEquity   Float    @default(0)
  avgEVEbitda     Float    @default(0)
  avgDividendYield Float   @default(0)
  totalMarketCap  Float    @default(0)
  stockCount      Int      @default(0)
  weightedPE      Float    @default(0)
  weightedPB      Float    @default(0)
  updatedAt       DateTime @updatedAt
  createdAt       DateTime @default(now())
}

model DataRefreshLog {
  id          String   @id @default(cuid())
  scope       String   // 'prices' | 'financials' | 'all' | 'technical'
  stocksUpdated Int    @default(0)
  stocksFailed  Int    @default(0)
  errors      String   @default("[]")
  startedAt   DateTime @default(now())
  completedAt DateTime?
}
