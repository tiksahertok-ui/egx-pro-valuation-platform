generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Stock {
  id                String   @id @default(cuid())
  ticker            String   @unique
  name              String
  nameAr            String
  sector            String
  industry          String
  marketCap         Float
  price             Float
  sharesOutstanding Float
  beta              Float    @default(1.0)
  dividendYield     Float    @default(0)
  peRatio           Float    @default(0)
  pbRatio           Float    @default(0)
  eps               Float    @default(0)
  bookValuePerShare Float    @default(0)
  fiftyTwoWeekHigh  Float    @default(0)
  fiftyTwoWeekLow   Float    @default(0)
  avgVolume         Float    @default(0)
  exchange          String   @default("EGX")
  currency          String   @default("EGP")
  listedDate        String   @default("")
  description       String   @default("")
  descriptionAr     String   @default("")
  logo              String   @default("")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  financials    FinancialData[]
  valuations    ValuationResult[]
  reports       AnalystReport[]
  priceHistory  PriceHistory[]
  technicals    TechnicalIndicator[]
}

model FinancialData {
  id                  String   @id @default(cuid())
  stockId             String
  year                Int
  quarter             Int      @default(0)
  revenue             Float
  costOfRevenue       Float    @default(0)
  grossProfit         Float    @default(0)
  operatingExpenses   Float    @default(0)
  operatingIncome     Float    @default(0)
  ebitda              Float    @default(0)
  depreciation        Float    @default(0)
  interestExpense     Float    @default(0)
  netIncome           Float    @default(0)
  eps                 Float    @default(0)
  dividendsPerShare   Float    @default(0)
  totalAssets         Float    @default(0)
  currentAssets       Float    @default(0)
  cash                Float    @default(0)
  totalLiabilities    Float    @default(0)
  currentLiabilities  Float    @default(0)
  longTermDebt        Float    @default(0)
  shortTermDebt       Float    @default(0)
  totalEquity         Float    @default(0)
  sharesOutstanding   Float    @default(0)
  operatingCashFlow   Float    @default(0)
  capitalExpenditure  Float    @default(0)
  freeCashFlow        Float    @default(0)
  changeInNWC         Float    @default(0)
  netBorrowing        Float    @default(0)
  taxRate             Float    @default(0.23)
  createdAt           DateTime @default(now())

  stock Stock @relation(fields: [stockId], references: [id], onDelete: Cascade)

  @@unique([stockId, year, quarter])
}

model ValuationResult {
  id          String   @id @default(cuid())
  stockId     String
  model       String
  fairValue   Float
  bearCase    Float
  baseCase    Float
  bullCase    Float
  upside      Float
  confidence  Float    @default(0.5)
  assumptions String   @default("")
  createdAt   DateTime @default(now())

  stock Stock @relation(fields: [stockId], references: [id], onDelete: Cascade)
}

model AnalystReport {
  id          String   @id @default(cuid())
  stockId     String
  title       String
  titleAr     String   @default("")
  content     String
  contentAr   String   @default("")
  rating      String   @default("Hold")
  targetPrice Float    @default(0)
  language    String   @default("en")
  createdAt   DateTime @default(now())

  stock Stock @relation(fields: [stockId], references: [id], onDelete: Cascade)
}

model PriceHistory {
  id        String   @id @default(cuid())
  stockId   String
  date      String
  open      Float
  high      Float
  low       Float
  close     Float
  volume    Float
  createdAt DateTime @default(now())

  stock Stock @relation(fields: [stockId], references: [id], onDelete: Cascade)

  @@unique([stockId, date])
}

model TechnicalIndicator {
  id              String   @id @default(cuid())
  stockId         String
  date            String
  rsi14           Float    @default(0)
  macd            Float    @default(0)
  macdSignal      Float    @default(0)
  macdHistogram   Float    @default(0)
  sma20           Float    @default(0)
  sma50           Float    @default(0)
  sma200          Float    @default(0)
  ema12           Float    @default(0)
  ema26           Float    @default(0)
  bbUpper         Float    @default(0)
  bbMiddle        Float    @default(0)
  bbLower         Float    @default(0)
  atr14           Float    @default(0)
  adx14           Float    @default(0)
  stochK          Float    @default(0)
  stochD          Float    @default(0)
  williamsR       Float    @default(0)
  cci14           Float    @default(0)
  obv             Float    @default(0)
  createdAt       DateTime @default(now())

  stock Stock @relation(fields: [stockId], references: [id], onDelete: Cascade)

  @@unique([stockId, date])
}

model SectorStats {
  id          String   @id @default(cuid())
  sector      String   @unique
  avgPE       Float    @default(0)
  avgPB       Float    @default(0)
  avgEVEbitda Float    @default(0)
  avgDivYield Float    @default(0)
  avgROE      Float    @default(0)
  avgROA      Float    @default(0)
  avgDebtEquity Float  @default(0)
  totalMarketCap Float @default(0)
  numCompanies Int     @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model EconomicIndicator {
  id              String   @id @default(cuid())
  name            String
  nameAr          String   @default("")
  value           Float
  previousValue   Float    @default(0)
  change          Float    @default(0)
  unit            String   @default("")
  source          String   @default("")
  date            String   @default("")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([name, date])
}
