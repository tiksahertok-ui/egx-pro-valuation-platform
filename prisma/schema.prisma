generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Stock {
  id                String   @id @default(cuid())
  ticker            String   @unique
  name              String
  nameAr            String
  sector            String
  industry          String
  isin              String   @default("")
  yahooSymbol       String   @default("")
  marketCap         Float    @default(0)
  price             Float    @default(0)
  sharesOutstanding Float    @default(0)
  beta              Float    @default(1.0)
  egx30Beta         Float    @default(1.0)
  dividendYield     Float    @default(0)
  peRatio           Float    @default(0)
  pbRatio           Float    @default(0)
  eps               Float    @default(0)
  bookValuePerShare Float    @default(0)
  fiftyTwoWeekHigh  Float    @default(0)
  fiftyTwoWeekLow   Float    @default(0)
  avgVolume         Float    @default(0)
  description       String   @default("")
  descriptionAr     String   @default("")
  lastPriceAt       DateTime?
  lastFinancialsAt  DateTime?
  lastSyncedAt      DateTime?
  minorityInterests Float    @default(0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  priceHistory        PriceHistory[]
  technicalIndicators TechnicalIndicator[]
  financialData       FinancialData[]
  valuationResults    ValuationResult[]
  supportResistance   SupportResistance[]
  alerts              Alert[]
  portfolioHoldings   PortfolioHolding[]
}

model FinancialData {
  id                 String   @id @default(cuid())
  stockId            String
  year               Int
  revenue            Float    @default(0)
  netIncome          Float    @default(0)
  totalAssets        Float    @default(0)
  totalEquity        Float    @default(0)
  totalDebt          Float    @default(0)
  operatingCashflow  Float    @default(0)
  freeCashflow       Float    @default(0)
  grossMargin        Float    @default(0)
  operatingMargin    Float    @default(0)
  profitMargin       Float    @default(0)
  roe                Float    @default(0)
  roa                Float    @default(0)
  debtToEquity       Float    @default(0)
  evToEbitda         Float    @default(0)
  dividendPerShare   Float    @default(0)
  eps                Float    @default(0)
  bookValuePerShare  Float    @default(0)
  revenueGrowth      Float    @default(0)
  earningsGrowth     Float    @default(0)
  usdRevenuePct      Float    @default(0)
  cashEquivalents    Float    @default(0)
  ebitda             Float    @default(0)
  lastSyncedAt       DateTime?
  createdAt          DateTime @default(now())

  stock Stock @relation(fields: [stockId], references: [id], onDelete: Cascade)

  @@unique([stockId, year])
}

model PriceHistory {
  id           String    @id @default(cuid())
  stockId      String
  date         DateTime
  open         Float
  high         Float
  low          Float
  close        Float
  volume       Float
  adjClose     Float     @default(0)
  lastSyncedAt DateTime?
  createdAt    DateTime  @default(now())

  stock Stock @relation(fields: [stockId], references: [id], onDelete: Cascade)

  @@unique([stockId, date])
}

model TechnicalIndicator {
  id           String   @id @default(cuid())
  stockId      String
  date         DateTime
  rsi14        Float    @default(0)
  macdLine     Float    @default(0)
  macdSignal   Float    @default(0)
  macdHist     Float    @default(0)
  bbUpper      Float    @default(0)
  bbMiddle     Float    @default(0)
  bbLower      Float    @default(0)
  sma20        Float    @default(0)
  sma50        Float    @default(0)
  sma200       Float    @default(0)
  ema12        Float    @default(0)
  ema26        Float    @default(0)
  atr14        Float    @default(0)
  adx14        Float    @default(0)
  stochasticK  Float    @default(0)
  stochasticD  Float    @default(0)
  williamsR    Float    @default(0)
  cci14        Float    @default(0)
  obv          Float    @default(0)
  createdAt    DateTime @default(now())

  stock Stock @relation(fields: [stockId], references: [id], onDelete: Cascade)

  @@unique([stockId, date])
}

model ValuationResult {
  id                 String   @id @default(cuid())
  stockId            String
  model              String
  fairValue          Float    @default(0)
  upsideDownside     Float    @default(0)
  confidence         Float    @default(0)
  assumptions        String   @default("{}")
  calculatedAt       DateTime @default(now())
  terminalGrowthCapped Boolean @default(false)

  stock Stock @relation(fields: [stockId], references: [id], onDelete: Cascade)

  @@unique([stockId, model])
}

model SectorStats {
  id               String   @id @default(cuid())
  sector           String   @unique
  sectorAr         String   @default("")
  avgPE            Float    @default(0)
  avgPB            Float    @default(0)
  avgROE           Float    @default(0)
  avgROA           Float    @default(0)
  avgDebtEquity    Float    @default(0)
  avgEVEbitda      Float    @default(0)
  avgDividendYield Float    @default(0)
  totalMarketCap   Float    @default(0)
  stockCount       Int      @default(0)
  weightedPE       Float    @default(0)
  weightedPB       Float    @default(0)
  updatedAt        DateTime @updatedAt
  createdAt        DateTime @default(now())
}

model EconomicIndicator {
  id          String @id @default(cuid())
  name        String @unique
  nameAr      String @default("")
  value       Float  @default(0)
  previous    Float  @default(0)
  change      Float  @default(0)
  unit        String @default("")
  source      String @default("")
  updatedAt   DateTime @updatedAt
  fetchedAt   DateTime?
}

model MarketParams {
  id                    String @id @default("default")
  riskFreeRate          Float  @default(0.18)
  equityRiskPremium     Float  @default(0.08)
  egx30PE               Float  @default(0)
  inflationRate         Float  @default(0.30)
  gdpGrowthRate         Float  @default(0.05)
  corporateDebtSpread   Float  @default(0.03)
  updatedAt             DateTime @updatedAt
}

model DataRefreshLog {
  id            String    @id @default(cuid())
  scope         String
  stocksUpdated Int       @default(0)
  stocksFailed  Int       @default(0)
  errors        String    @default("[]")
  startedAt     DateTime  @default(now())
  completedAt   DateTime?
}

/// P1.4: Support & Resistance levels
model SupportResistance {
  id           String   @id @default(cuid())
  stockId      String
  date         DateTime
  pivot        Float    @default(0)
  support1     Float    @default(0)
  resistance1  Float    @default(0)
  support2     Float    @default(0)
  resistance2  Float    @default(0)
  vwap         Float    @default(0)
  swingHigh    Float    @default(0)
  swingLow     Float    @default(0)
  createdAt    DateTime @default(now())

  stock Stock @relation(fields: [stockId], references: [id], onDelete: Cascade)

  @@unique([stockId, date])
}

/// P2.1: Portfolio models
model Portfolio {
  id          String   @id @default(cuid())
  name        String
  description String   @default("")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  holdings PortfolioHolding[]
}

model PortfolioHolding {
  id          String   @id @default(cuid())
  portfolioId String
  stockId     String
  shares      Float    @default(0)
  avgCost     Float    @default(0)
  addedAt     DateTime @default(now())

  portfolio Portfolio @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
  stock     Stock     @relation(fields: [stockId], references: [id], onDelete: Cascade)

  @@unique([portfolioId, stockId])
}

/// P2.4: Alerting system
model Alert {
  id        String   @id @default(cuid())
  stockId   String
  type      String   // 'price_target', 'support_breach', 'resistance_break', 'fair_value_hit'
  threshold Float
  isActive  Boolean  @default(true)
  triggered Boolean  @default(false)
  createdAt DateTime @default(now())

  stock Stock @relation(fields: [stockId], references: [id], onDelete: Cascade)
}
