# EGX Pro Valuation Platform - Environment Variables
# Copy this file to .env and fill in the values

# ─── Database ────────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@localhost:5432/egx_pro"

# ─── Authentication ──────────────────────────────────────────
NEXTAUTH_SECRET="your-nextauth-secret-here-generate-with-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"

# Admin credentials (used for initial setup / fallback before User model is seeded)
ADMIN_EMAIL="admin@egxpro.com"
ADMIN_PASSWORD="change-me-to-a-strong-password"

# ─── Cron / Data Refresh ─────────────────────────────────────
CRON_SECRET="your-cron-secret-here-generate-with-openssl-rand-base64-32"

# ─── AI Report Generation (z-ai-web-dev-sdk) ────────────────
# The SDK auto-configures; no separate API key is required.

# ─── Optional ────────────────────────────────────────────────
# NODE_ENV="development"
# NEXT_PUBLIC_APP_URL="http://localhost:3000"
