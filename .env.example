# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key

# Database — Supabase PostgreSQL (Transaction Pooler for serverless)
# Get from: Supabase Dashboard → Settings → Database → Connection string
# Pooler (transaction mode): port 6543
# Direct (session mode): port 5432
DATABASE_URL="postgresql://postgres.[project-ref]:[db-password]@aws-0-[region].pooler.supabase.com:6543/postgres"
DIRECT_URL="postgresql://postgres.[project-ref]:[db-password]@aws-0-[region].pooler.supabase.com:5432/postgres"

# NextAuth
ADMIN_EMAIL=admin@egxpro.com
ADMIN_PASSWORD=admin123
NEXTAUTH_SECRET=           # Generate with: openssl rand -base64 32
NEXTAUTH_URL=http://localhost:3000

# Scheduled data refresh (cron endpoint)
CRON_SECRET=               # Generate with: openssl rand -base64 32
