# Database — PostgreSQL (Neon recommended for serverless)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/egx_pro?schema=public"

# NextAuth
ADMIN_EMAIL=admin@egxpro.com
ADMIN_PASSWORD=          # Plain text for first login; auto-hashed to User table
NEXTAUTH_SECRET=         # Generate with: openssl rand -base64 32
NEXTAUTH_URL=http://localhost:3000

# Scheduled data refresh (cron endpoint)
CRON_SECRET=             # Generate with: openssl rand -base64 32
